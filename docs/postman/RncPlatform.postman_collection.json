              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/rncs?term={{searchTerm}}&pageSize=20&cursor=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rncs"],
              "query": [
                { "key": "term", "value": "{{searchTerm}}" },
                { "key": "pageSize", "value": "20" },
                { "key": "cursor", "value": "" }
              ]
            }
          }
        },
